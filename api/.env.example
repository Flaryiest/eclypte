# Eclypte API environment template — copy to api/.env and fill in.
# load_dotenv() reads api/.env on startup. Only the R2 block is required for
# real /v1/* calls; everything else is optional and degrades gracefully when
# unset (e.g. no Redis -> polling, no Postgres -> R2 JSON run store).

# --- Cloudflare R2 (required for real /v1/* calls) ---
ECLYPTE_R2_ACCOUNT_ID=
ECLYPTE_R2_BUCKET=
ECLYPTE_R2_ACCESS_KEY_ID=
ECLYPTE_R2_SECRET_ACCESS_KEY=
ECLYPTE_R2_REGION_NAME=auto
# Optional override; defaults to https://<account_id>.r2.cloudflarestorage.com
ECLYPTE_R2_ENDPOINT_URL=

# --- Auth (temporary) ---
# Fallback user id used when no X-User-Id header is present.
ECLYPTE_DEFAULT_USER_ID=local_dev

# --- Server ---
# Port for `python -m api.main` (default 8000).
PORT=8000
# Comma-separated CORS allowlist; defaults to the Vercel app + localhost.
ECLYPTE_CORS_ORIGINS=

# --- Optional datastores ---
# Postgres run/event/progress store; falls back to R2 JSON when unset.
DATABASE_URL=
# Redis realtime run-update stream; falls back to polling when unset.
REDIS_URL=

# --- Modal -> API worker progress ---
# Lets Modal workers POST live progress to /internal/progress. The token must
# match the value Modal workers send (Worker secret ECLYPTE_INTERNAL_TOKEN).
# Without these, render/analysis progress flows via the slower R2-event path.
ECLYPTE_INTERNAL_PROGRESS_URL=
ECLYPTE_INTERNAL_PROGRESS_TOKEN=

# --- OpenAI (agent timeline planning + publishing captions) ---
OPENAI_API_KEY=
# Optional caption model override (default gpt-5.4-mini).
ECLYPTE_CAPTION_MODEL=

# --- Buffer publishing (Instagram Reels) ---
BUFFER_API_KEY=
# Optional Buffer API base (default https://api.buffer.com).
BUFFER_API_URL=
BUFFER_INSTAGRAM_CHANNEL_ID=
# Public base URL for R2 publishing copies; required to send to Buffer.
ECLYPTE_R2_PUBLIC_BASE_URL=

# --- Misc ---
# Optional override for workflow scratch temp dir (default: system temp).
ECLYPTE_TEMP_DIR=
